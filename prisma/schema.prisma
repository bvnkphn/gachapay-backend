// Prisma Schema for PostgreSQL 18
generator client {
  provider = "prisma-client-js"
}

enum GameLabel {
  NONE
  HOT
  NEW
  SALE
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                BigInt    @id @default(autoincrement())
  uuid              String    @unique @default(uuid()) @db.Char(36)
  email             String    @unique @db.VarChar(255)
  password_hash     String?   @db.VarChar(255)
  tier              String?   @db.VarChar(50)
  point_balance     Int       @default(0)
  wallet_balance    Decimal   @default(0) @db.Decimal(12, 2)
  role              UserRole  @default(USER)
  created_at        DateTime  @default(now()) @db.Timestamp(0)
  isEmailVerified   Boolean   @default(false)
  updated_at        DateTime  @updatedAt @db.Timestamp(0)
  last_login_at     DateTime? @db.Timestamp(0)
  
  name              String?   @db.VarChar(255)
  provider          String    @default("local") @db.VarChar(20)
  providerId        String?   @db.VarChar(255)
  
  orders            Order[]
  transactions      Transaction[]
  passwordResets    PasswordReset[]
  otpRequests       OtpRequest[]
  couponUsages      CouponUsage[]
  topupTransactions TopupTransaction[]
  adminLogs         AdminLog[]

  @@index([email])
  @@index([uuid])
  @@index([provider, providerId])
  @@map("users")
}

model AdminLog {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  action      String   @db.VarChar(100)
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamp(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_logs")
}

model PasswordReset {
  id            BigInt    @id @default(autoincrement())
  uuid          String    @unique @default(uuid()) @db.Char(36)
  user_id       BigInt
  token_hash    String    @db.VarChar(255)
  expires_at    DateTime  @db.Timestamp(0)
  used_at       DateTime? @db.Timestamp(0)
  ip_address    String?   @db.VarChar(45)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@index([user_id])
  @@index([token_hash])
  @@map("password_resets")
}

model OtpRequest {
  id            BigInt    @id @default(autoincrement())
  uuid          String    @unique @default(uuid()) @db.Char(36)
  user_id       BigInt
  otp_hash      String    @db.VarChar(255)
  expires_at    DateTime  @db.Timestamp(0)
  attempt_count Int       @default(0)
  ip_address    String?   @db.VarChar(45)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@index([user_id])
  @@index([otp_hash])
  @@map("otp_requests")
}

model Order {
  id                    BigInt   @id @default(autoincrement())
  userId                BigInt?  // Nullable to support guest orders ← เอาของทีม
  gameId                BigInt?
  gameName              String   @db.VarChar(255)
  packageId             BigInt?
  packageName           String   @db.VarChar(255)
  packagePrice          Decimal  @db.Decimal(10, 2)
  uid                   String   @db.VarChar(255)
  email                 String   @db.VarChar(255)
  externalGameSlug      String?  @db.VarChar(100)
  externalPackageSku    String?  @db.VarChar(100)
  couponCode            String?  @db.VarChar(100)
  discountAmount        Decimal  @default(0) @db.Decimal(10, 2)
  finalPrice            Decimal? @db.Decimal(10, 2)
  status                String   @default("pending") @db.VarChar(20)
  paymentMethod         String?  @db.VarChar(50)
  createdAt             DateTime @default(now()) @db.Timestamp(0)
  updatedAt             DateTime @updatedAt @db.Timestamp(0)
  
  user                  User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  game                  Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  package               GamePackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  transactions          TopupTransaction[]
  
  @@index([userId])
  @@index([gameId])
  @@index([packageId])
  @@index([externalGameSlug])
  @@index([externalPackageSku])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model Transaction {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt
  type          String   @db.VarChar(50)
  amount        Decimal  @db.Decimal(10, 2)
  description   String?  @db.Text
  status        String   @default("completed") @db.VarChar(20)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model Game {
  id          BigInt    @id @default(autoincrement())
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  image       String?   @db.VarChar(500)
  categoryId  BigInt?
  label       GameLabel @default(NONE)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamp(0)
  updatedAt   DateTime  @updatedAt @db.Timestamp(0)

  category    GameCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  packages    GamePackage[]
  inputFields GameInputField[]
  orders      Order[]

  @@index([slug])
  @@index([isActive])
  @@index([categoryId])
  @@map("games")
}

model GameCategory {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)

  games       Game[]

  @@index([isActive])
  @@map("game_categories")
}

model GamePackage {
  id              BigInt    @id @default(autoincrement())
  gameId          BigInt
  sku             String    @unique @db.VarChar(100)
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  price           Decimal   @db.Decimal(10, 2)
  originalPrice   Decimal   @default(0) @db.Decimal(10, 2)
  cost            Decimal   @default(0) @db.Decimal(10, 2)
  discount        Int       @default(0)
  flashSalePrice  Decimal?  @db.Decimal(10, 2)
  flashSaleStart  DateTime? @db.Timestamp(0)
  flashSaleEnd    DateTime? @db.Timestamp(0)
  quota           Int?
  soldCount       Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamp(0)
  updatedAt       DateTime  @updatedAt @db.Timestamp(0)
  
  game            Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  orders          Order[]
  
  @@index([gameId])
  @@index([isActive])
  @@index([sku])
  @@index([flashSaleEnd])
  @@map("game_packages")
}

model GameInputField {
  id            BigInt   @id @default(autoincrement())
  gameId        BigInt
  key           String   @db.VarChar(100)
  label         String   @db.VarChar(255)
  placeholder   String?  @db.VarChar(255)
  type          String   @default("text") @db.VarChar(50)
  required      Boolean  @default(true)
  regex         String?  @db.VarChar(500)
  helpText      String?  @db.Text
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @db.Timestamp(0)

  game          Game                   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  options       GameInputFieldOption[]

  @@index([gameId])
  @@index([isActive])
  @@unique([gameId, key])
  @@map("game_input_fields")
}

model GameInputFieldOption {
  id            BigInt   @id @default(autoincrement())
  fieldId       BigInt
  label         String   @db.VarChar(255)
  value         String   @db.VarChar(500)
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamp(0)

  field         GameInputField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, value])
  @@index([fieldId])
  @@index([isActive])
  @@map("game_input_field_options")
}

model Banner {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Char(36)
  image       String   @db.VarChar(500)
  title       String?  @db.VarChar(255)
  description String?  @db.Text
  redirectUrl String   @db.VarChar(500)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  
  @@index([isActive])
  @@index([order])
  @@index([createdAt])
  @@map("banners")
}

enum CouponDiscountType {
  FIXED
  PERCENTAGE
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  INACTIVE
}

model Coupon {
  id                   BigInt             @id @default(autoincrement())
  uuid                 String             @unique @default(uuid()) @db.Char(36)
  code                 String             @unique @db.VarChar(50)
  description          String?            @db.Text
  discountType         CouponDiscountType @default(FIXED)
  discountValue        Decimal            @db.Decimal(10, 2)
  minimumAmount        Decimal            @default(0) @db.Decimal(10, 2)
  maximumUses          Int                @default(0)
  currentUsageCount    Int                @default(0)
  usagePerUser         Int                @default(1)
  startDate            DateTime           @db.Timestamp(0)
  expiryDate           DateTime           @db.Timestamp(0)
  applicableGameIds    BigInt[]
  applicablePackageIds BigInt[]
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now()) @db.Timestamp(0)
  updatedAt            DateTime           @updatedAt @db.Timestamp(0)
  
  usages               CouponUsage[]
  
  @@index([code])
  @@index([isActive])
  @@index([startDate])
  @@index([expiryDate])
  @@map("coupons")
}

model CouponUsage {
  id              BigInt   @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.Char(36)
  couponId        BigInt
  userId          BigInt
  usedAmount      Decimal  @db.Decimal(10, 2)
  discountAmount  Decimal  @db.Decimal(10, 2)
  orderId         BigInt?
  usedAt          DateTime @default(now()) @db.Timestamp(0)
  ipAddress       String?  @db.VarChar(45)
  
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([couponId, userId, orderId])
  @@index([couponId])
  @@index([userId])
  @@index([usedAt])
  @@map("coupon_usages")
}

model PaymentMethod {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  icon        String?  @db.VarChar(50)
  color       String?  @db.VarChar(20)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)

  topupTransactions TopupTransaction[]

  @@index([isActive])
  @@map("payment_methods")
}

model TopupTransaction {
  id            BigInt    @id @default(autoincrement())
  referenceId   String    @unique @db.VarChar(50)
  userId        BigInt
  orderId       BigInt?
  methodId      BigInt
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("pending") @db.VarChar(20)
  paymentUrl    String?   @db.VarChar(500)
  expiresAt     DateTime? @db.Timestamp(0) @map("expires_at")
  completedAt   DateTime? @db.Timestamp(0)
  createdAt     DateTime  @default(now()) @db.Timestamp(0)
  updatedAt     DateTime  @updatedAt @db.Timestamp(0)

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  method        PaymentMethod @relation(fields: [methodId], references: [id])
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@index([referenceId])
  @@map("topup_transactions")
}
