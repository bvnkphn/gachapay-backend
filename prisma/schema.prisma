generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  uuid                 String    @id @default(uuid())
  email                String    @unique
  password_hash        String?
  displayName          String?
  name                 String?
  avatar               String?
  provider             String?
  providerId           String?
  isEmailVerified      Boolean   @default(false)
  otpCode              String?
  otpExpires           DateTime?
  otpAttempts          Int       @default(0)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  orders        Order[]
  loyaltyPoints LoyaltyPoints?

  @@map("users")
}

model Game {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  description String?
  image       String?
  category    String?
  platform    String?
  currency    String?
  accent      String?
  isHot       Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packages TopupPackage[]
  orders   Order[]

  @@map("games")
}

model TopupPackage {
  id          Int      @id @default(autoincrement())
  gameId      Int
  name        String
  amount      Int
  bonusAmount Int      @default(0)
  price       Decimal  @db.Decimal(10, 2)
  discount    Int      @default(0)
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  game   Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([gameId, name])
  @@map("topup_packages")
}

model Banner {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  tag         String?
  href        String   @default("/topup")
  bg          String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

model Order {
  id             String      @id @default(uuid())
  orderNumber    String      @unique
  userId         String?
  gameId         Int
  packageId      Int?
  buyerEmail     String
  gameAccountId  String
  gameServer     String?
  gameUsername   String?
  packageName    String?
  amount         Int
  bonusAmount    Int         @default(0)
  currency       String?
  unitPrice      Decimal     @db.Decimal(10, 2)
  totalPrice     Decimal     @db.Decimal(10, 2)
  couponCode     String?
  couponDiscount Decimal?    @db.Decimal(10, 2)
  pointsEarned   Int         @default(0)
  status         OrderStatus @default(PENDING)
  paymentMethod  String?
  paymentRef     String?
  paidAt         DateTime?
  deliveredAt    DateTime?
  deliveryNote   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User?          @relation(fields: [userId], references: [uuid])
  game       Game           @relation(fields: [gameId], references: [id])
  package    TopupPackage?  @relation(fields: [packageId], references: [id])
  payments   Payment[]
  statusLogs OrderStatusLog[]

  @@index([buyerEmail])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String
  provider    String
  providerRef String?
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("THB")
  status      PaymentStatus @default(PENDING)
  rawResponse Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model OrderStatusLog {
  id        Int      @id @default(autoincrement())
  orderId   String
  oldStatus String?
  newStatus String
  note      String?
  createdBy String   @default("system")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_logs")
}

model Coupon {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  description    String?
  discountType   String
  discountValue  Decimal   @db.Decimal(10, 2)
  minOrderAmount Decimal   @default(0) @db.Decimal(10, 2)
  maxDiscount    Decimal?  @db.Decimal(10, 2)
  usageLimit     Int?
  usageCount     Int       @default(0)
  perUserLimit   Int       @default(1)
  isActive       Boolean   @default(true)
  startsAt       DateTime  @default(now())
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id       Int      @id @default(autoincrement())
  couponId Int
  userId   String?
  email    String
  orderId  String?
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])

  @@map("coupon_usages")
}

model LoyaltyPoints {
  id          Int      @id @default(autoincrement())
  userId      String   @unique
  balance     Int      @default(0)
  totalEarned Int      @default(0)
  totalSpent  Int      @default(0)
  updatedAt   DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [uuid])
  transactions PointTransaction[]

  @@map("loyalty_points")
}

model PointTransaction {
  id          Int      @id @default(autoincrement())
  userId      String
  orderId     String?
  type        String
  points      Int
  description String?
  createdAt   DateTime @default(now())

  loyaltyPoints LoyaltyPoints @relation(fields: [userId], references: [userId])

  @@map("point_transactions")
}
