// Prisma Schema for PostgreSQL 18
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GameLabel {
  NONE
  HOT
  NEW
  SALE
}

enum UserRole {
  USER
  ADMIN
}

enum TicketStatus {
  new
  inprogress
  resolved
  closed
}

model User {
  id                BigInt    @id @default(autoincrement())
  uuid              String    @unique @default(uuid()) @db.VarChar(36)
  email             String    @unique @db.VarChar(255)
  password_hash     String?   @db.VarChar(255)
  tier              String?   @db.VarChar(50)
  point_balance     Int       @default(0)
  wallet_balance    Decimal   @default(0) @db.Decimal(12, 2)
  role              UserRole  @default(USER)
  created_at        DateTime  @default(now()) @db.Timestamp(0)
  isEmailVerified   Boolean   @default(false)
  updated_at        DateTime  @updatedAt @db.Timestamp(0)
  last_login_at     DateTime? @db.Timestamp(0)
  name              String?   @db.VarChar(255)
  provider          String    @default("local") @db.VarChar(20)
  providerId        String?   @db.VarChar(255)
  orders            Order[]
  transactions      Transaction[]
  passwordResets    PasswordReset[]
  otpRequests       OtpRequest[]
  couponUsages      CouponUsage[]
  topupTransactions TopupTransaction[]
  adminLogs         AdminLog[]
  tickets           SupportTicket[]   @relation("TicketUser")
  assignedTickets   SupportTicket[]   @relation("TicketAssignee")
  ticketMessages    TicketMessage[]
  ticketHistories   TicketHistory[]
  gachaSpins        GachaSpin[]
  referralsSent     Referral[]        @relation("ReferralsSent")
  referralReceived  Referral?         @relation("ReferralReceived")
  addresses         UserAddress[]
  bookmarks         Bookmark[]
  @@index([email])
  @@index([uuid])
  @@index([provider, providerId])
  @@map("users")
}

model AdminLog {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  action      String   @db.VarChar(100)
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_logs")
}

model PasswordReset {
  id            BigInt    @id @default(autoincrement())
  uuid          String    @unique @default(uuid()) @db.Char(36)
  user_id       BigInt
  token_hash    String    @db.VarChar(255)
  expires_at    DateTime  @db.Timestamp(0)
  used_at       DateTime? @db.Timestamp(0)
  ip_address    String?   @db.VarChar(45)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
  @@index([token_hash])
  @@map("password_resets")
}

model OtpRequest {
  id            BigInt    @id @default(autoincrement())
  uuid          String    @unique @default(uuid()) @db.Char(36)
  user_id       BigInt
  otp_hash      String    @db.VarChar(255)
  expires_at    DateTime  @db.Timestamp(0)
  attempt_count Int       @default(0)
  ip_address    String?   @db.VarChar(45)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
  @@index([otp_hash])
  @@map("otp_requests")
}

model Order {
  id                    BigInt   @id @default(autoincrement())
  userId                BigInt?
  gameId                BigInt?
  gameName              String   @db.VarChar(255)
  packageId             BigInt?
  packageName           String   @db.VarChar(255)
  packagePrice          Decimal  @db.Decimal(10, 2)
  uid                   String   @db.VarChar(255)
  email                 String   @db.VarChar(255)
  externalGameSlug      String?  @db.VarChar(100)
  externalPackageSku    String?  @db.VarChar(100)
  couponCode            String?  @db.VarChar(100)
  discountAmount        Decimal  @default(0) @db.Decimal(10, 2)
  finalPrice            Decimal? @db.Decimal(10, 2)
  status                String   @default("pending") @db.VarChar(20)
  paymentMethod         String?  @db.VarChar(50)
  createdAt             DateTime @default(now()) @db.Timestamp(0)
  updatedAt             DateTime @updatedAt @db.Timestamp(0)
  user                  User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  game                  Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  package               GamePackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  transactions          TopupTransaction[]
  @@index([userId])
  @@index([gameId])
  @@index([packageId])
  @@index([externalGameSlug])
  @@index([externalPackageSku])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model Transaction {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt
  type          String   @db.VarChar(50)
  amount        Decimal  @db.Decimal(10, 2)
  description   String?  @db.Text
  status        String   @default("completed") @db.VarChar(20)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model Game {
  id          BigInt    @id @default(autoincrement())
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  image       String?   @db.VarChar(500)
  categoryId  BigInt?
  label       GameLabel @default(NONE)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamp(0)
  updatedAt   DateTime  @updatedAt @db.Timestamp(0)
  category    GameCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  packages    GamePackage[]
  inputFields GameInputField[]
  orders      Order[]
  bookmarks   Bookmark[]
  @@index([slug])
  @@index([isActive])
  @@index([categoryId])
  @@map("games")
}

model GameCategory {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  games       Game[]
  @@index([isActive])
  @@map("game_categories")
}

model GamePackage {
  id              BigInt    @id @default(autoincrement())
  gameId          BigInt
  sku             String    @unique @db.VarChar(100)
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  price           Decimal   @db.Decimal(10, 2)
  originalPrice   Decimal   @default(0) @db.Decimal(10, 2)
  cost            Decimal   @default(0) @db.Decimal(10, 2)
  discount        Int       @default(0)
  flashSalePrice  Decimal?  @db.Decimal(10, 2)
  flashSaleStart  DateTime? @db.Timestamp(0)
  flashSaleEnd    DateTime? @db.Timestamp(0)
  quota           Int?
  soldCount       Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamp(0)
  updatedAt       DateTime  @updatedAt @db.Timestamp(0)
  game            Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  orders          Order[]
  @@index([gameId])
  @@index([isActive])
  @@index([sku])
  @@index([flashSaleEnd])
  @@map("game_packages")
}

model GameInputField {
  id            BigInt   @id @default(autoincrement())
  gameId        BigInt
  key           String   @db.VarChar(100)
  label         String   @db.VarChar(255)
  placeholder   String?  @db.VarChar(255)
  type          String   @default("text") @db.VarChar(50)
  required      Boolean  @default(true)
  regex         String?  @db.VarChar(500)
  helpText      String?  @db.Text
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @db.Timestamp(0)
  game          Game                   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  options       GameInputFieldOption[]
  @@index([gameId])
  @@index([isActive])
  @@unique([gameId, key])
  @@map("game_input_fields")
}

model GameInputFieldOption {
  id            BigInt   @id @default(autoincrement())
  fieldId       BigInt
  label         String   @db.VarChar(255)
  value         String   @db.VarChar(500)
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  field         GameInputField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  @@unique([fieldId, value])
  @@index([fieldId])
  @@index([isActive])
  @@map("game_input_field_options")
}

model Banner {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Char(36)
  image       String   @db.VarChar(500)
  title       String?  @db.VarChar(255)
  description String?  @db.Text
  redirectUrl String   @db.VarChar(500)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  @@index([isActive])
  @@index([order])
  @@index([createdAt])
  @@map("banners")
}

enum CouponDiscountType {
  FIXED
  PERCENTAGE
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  INACTIVE
}

model Coupon {
  id                   BigInt             @id @default(autoincrement())
  uuid                 String             @unique @default(uuid()) @db.Char(36)
  code                 String             @unique @db.VarChar(50)
  description          String?            @db.Text
  discountType         CouponDiscountType @default(FIXED)
  discountValue        Decimal            @db.Decimal(10, 2)
  minimumAmount        Decimal            @default(0) @db.Decimal(10, 2)
  maximumUses          Int                @default(0)
  currentUsageCount    Int                @default(0)
  usagePerUser         Int                @default(1)
  startDate            DateTime           @db.Timestamp(0)
  expiryDate           DateTime           @db.Timestamp(0)
  applicableGameIds    BigInt[]
  applicablePackageIds BigInt[]
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now()) @db.Timestamp(0)
  updatedAt            DateTime           @updatedAt @db.Timestamp(0)
  usages               CouponUsage[]
  @@index([code])
  @@index([isActive])
  @@index([startDate])
  @@index([expiryDate])
  @@map("coupons")
}

model CouponUsage {
  id              BigInt   @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.Char(36)
  couponId        BigInt
  userId          BigInt
  usedAmount      Decimal  @db.Decimal(10, 2)
  discountAmount  Decimal  @db.Decimal(10, 2)
  orderId         BigInt?
  usedAt          DateTime @default(now()) @db.Timestamp(0)
  ipAddress       String?  @db.VarChar(45)
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([couponId, userId, orderId])
  @@index([couponId])
  @@index([userId])
  @@index([usedAt])
  @@map("coupon_usages")
}

model PaymentMethod {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  icon        String?  @db.VarChar(50)
  color       String?  @db.VarChar(20)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  topupTransactions TopupTransaction[]
  @@index([isActive])
  @@map("payment_methods")
}

model TopupTransaction {
  id            BigInt    @id @default(autoincrement())
  referenceId   String    @unique @db.VarChar(50)
  userId        BigInt
  orderId       BigInt?
  methodId      BigInt
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("pending") @db.VarChar(20)
  slipUrl       String?   @db.VarChar(500)
  bankCode      String?   @db.VarChar(20)
  adminNote     String?   @db.Text
  paymentUrl    String?   @db.VarChar(500)
  expiresAt     DateTime? @db.Timestamp(0) @map("expires_at")
  completedAt   DateTime? @db.Timestamp(0)
  createdAt     DateTime  @default(now()) @db.Timestamp(0)
  updatedAt     DateTime  @updatedAt @db.Timestamp(0)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  method        PaymentMethod @relation(fields: [methodId], references: [id])
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@index([referenceId])
  @@map("topup_transactions")
}

model GachaSpin {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  orderId     BigInt?  
  prizeAmount Decimal  @db.Decimal(10,2)
  prizeLabel  String?  @db.VarChar(255)
  won         Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamp(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([orderId])
  @@map("gacha_spins")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @db.Timestamp(0)
  @@map("system_settings")
}

// ── Support Ticket System ─────────────────────────────────────────
model SupportTicket {
  id           BigInt        @id @default(autoincrement())
  ticketNo     String        @unique @db.VarChar(20)
  userId       BigInt?
  assigneeId   BigInt?
  email        String        @db.VarChar(255)
  name         String        @db.VarChar(255)
  subject      String        @db.VarChar(500)
  status       TicketStatus  @default(new)
  priority     String        @default("normal") @db.VarChar(20)
  category     String?       @db.VarChar(100)
  orderId      BigInt?
  createdAt    DateTime      @default(now()) @db.Timestamp(0)
  updatedAt    DateTime      @updatedAt @db.Timestamp(0)
  closedAt     DateTime?     @db.Timestamp(0)
  user         User?          @relation("TicketUser",     fields: [userId],     references: [id], onDelete: SetNull)
  assignee     User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages     TicketMessage[]
  histories    TicketHistory[]
  @@index([userId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([orderId])
  @@index([createdAt])
  @@map("support_tickets")
}

model TicketMessage {
  id         BigInt   @id @default(autoincrement())
  ticketId   BigInt
  userId     BigInt?
  senderType String   @db.VarChar(10)
  message    String   @db.Text
  imageUrl   String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @db.Timestamp(0)
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_messages")
}

model TicketHistory {
  id         BigInt   @id @default(autoincrement())
  ticketId   BigInt
  adminId    BigInt?
  action     String   @db.VarChar(50)
  fromValue  String?  @db.VarChar(100)
  toValue    String?  @db.VarChar(100)
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @db.Timestamp(0)
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  admin      User?         @relation(fields: [adminId], references: [id], onDelete: SetNull)
  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_histories")
}

// ── FAQ & Guide System ────────────────────────────────────────────
model FaqItem {
  id        Int      @id @default(autoincrement())
  question  String   @db.VarChar(500)
  answer    String   @db.Text
  videoUrl  String?  @db.VarChar(500)
  category  String   @default("general") @db.VarChar(100)
  order     Int      @default(0)
  viewCount Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)
  @@index([isActive])
  @@index([category])
  @@index([order])
  @@map("faq_items")
}

// ── Referral System ──────────────────────────────────────────────
model Referral {
  id             BigInt   @id @default(autoincrement())
  referrerId     BigInt
  referredId     BigInt   @unique
  status         String   @default("pending") @db.VarChar(20) // "pending", "completed"
  rewardAmount   Int      @default(10)
  createdAt      DateTime @default(now()) @db.Timestamp(0)
  
  referrer       User     @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referred       User     @relation("ReferralReceived", fields: [referredId], references: [id], onDelete: Cascade)
  
  @@index([referrerId])
  @@index([referredId])
  @@map("referrals")
}

model UserAddress {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt
  recipientName String   @db.VarChar(255)
  phone         String   @db.VarChar(20)
  addressLine1  String   @db.VarChar(255)
  addressLine2  String?  @db.VarChar(255)
  subDistrict   String?  @db.VarChar(100)
  district      String   @db.VarChar(100)
  province      String   @db.VarChar(100)
  postalCode    String   @db.VarChar(20)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @db.Timestamp(0)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_addresses")
}

model Bookmark {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  gameId    BigInt
  createdAt DateTime @default(now()) @db.Timestamp(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@map("bookmarks")
}

// ── API Credit Management ─────────────────────────────────────────
model ApiCreditProvider {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(100)
  code           String    @unique @db.VarChar(50)
  description    String?   @db.Text
  iconUrl        String?   @db.Text
  apiBaseUrl     String?   @db.Text
  balance        Decimal   @default(0) @db.Decimal(12, 2)
  alertThreshold Decimal   @default(1000) @db.Decimal(12, 2)
  enabled        Boolean   @default(true)
  lastCheckedAt  DateTime? @db.Timestamp(0)
  createdAt      DateTime  @default(now()) @db.Timestamp(0)
  updatedAt      DateTime  @updatedAt @db.Timestamp(0)

  transactions ApiCreditTransaction[]

  @@map("api_credit_providers")
}

model ApiCreditTransaction {
  id           Int      @id @default(autoincrement())
  providerId   Int
  type         String   @db.VarChar(20)
  amount       Decimal  @db.Decimal(12, 2)
  balanceAfter Decimal  @db.Decimal(12, 2)
  note         String?  @db.Text
  orderId      BigInt?
  createdAt    DateTime @default(now()) @db.Timestamp(0)

  provider ApiCreditProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("api_credit_transactions")
}
