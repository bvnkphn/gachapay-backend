# ==============================================================================
# GachaPay Backend Environment Configuration
# ==============================================================================

# 🌐 Application Server Settings
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# 🗄️ Database Connection (PostgreSQL)
# DATABASE_URL is used for general connections (pooled or direct)
DATABASE_URL="postgresql://gachapay:gachapay1234@localhost:5432/game_topup_db?schema=public"

# DIRECT_URL is required by Prisma for Supabase or direct migrations.
# In local development, you should set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://gachapay:gachapay1234@localhost:5432/game_topup_db?schema=public"

# 🔑 JWT Authentication Settings
JWT_SECRET="your_very_secure_and_long_jwt_secret_key_here"
JWT_EXPIRES_IN="7d"

# 🛡️ Webhook Security Secret
# Used to secure webhook endpoints on host deployment.
# In local development, you can leave this blank or bypass.
WEBHOOK_SECRET="local-development-secret-bypass"

# 📧 SMTP Email Configuration (Nodemailer)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-gmail-app-password"
EMAIL_FROM="GachaPay <noreply@gachapay.com>"

# 🔐 OAuth Configurations (Optional in Dev - Mocked if not set)
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Facebook OAuth
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:3001/api/auth/facebook/callback"

# 🛠️ Seeding / Initial Admin Defaults
ADMIN_DEFAULT_PASSWORD="Pass1234_change_me"
USER_DEFAULT_PASSWORD="Test1234!_change_me"
