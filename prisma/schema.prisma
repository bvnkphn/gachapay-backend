// Prisma Schema for PostgreSQL 18
generator client {
  provider = "prisma-client-js"
}

enum GameLabel {
  NONE
  HOT
  NEW
  SALE
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                BigInt    @id @default(autoincrement())
  uuid              String    @unique @default(uuid()) @db.Char(36)
  email             String    @unique @db.VarChar(255)
  password_hash     String?   @db.VarChar(255)
  tier              String?   @db.VarChar(50)
  point_balance     Int       @default(0)
  wallet_balance    Decimal   @default(0) @db.Decimal(12, 2)
  role              UserRole  @default(USER)
  created_at        DateTime  @default(now()) @db.Timestamp(0)
  isEmailVerified   Boolean   @default(false)
  updated_at        DateTime  @updatedAt @db.Timestamp(0)
  last_login_at     DateTime? @db.Timestamp(0)
  
  // OAuth fields
  name              String?   @db.VarChar(255)
  provider          String    @default("local") @db.VarChar(20) // local, google, facebook
  providerId        String?   @db.VarChar(255)
  
  orders            Order[]
  transactions      Transaction[]
  passwordResets    PasswordReset[]
  otpRequests       OtpRequest[]
  
  @@index([email])
  @@index([uuid])
  @@index([provider, providerId])
  @@map("users")
}

model PasswordReset {
  id            BigInt    @id @default(autoincrement())
  uuid          String    @unique @default(uuid()) @db.Char(36)
  user_id       BigInt
  token_hash    String    @db.VarChar(255)
  expires_at    DateTime  @db.Timestamp(0)
  used_at       DateTime? @db.Timestamp(0)
  ip_address    String?   @db.VarChar(45)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@index([user_id])
  @@index([token_hash])
  @@map("password_resets")
}

model OtpRequest {
  id            BigInt    @id @default(autoincrement())
  uuid          String    @unique @default(uuid()) @db.Char(36)
  user_id       BigInt
  otp_hash      String    @db.VarChar(255)
  expires_at    DateTime  @db.Timestamp(0)
  attempt_count Int       @default(0)
  ip_address    String?   @db.VarChar(45)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@index([user_id])
  @@index([otp_hash])
  @@map("otp_requests")
}

model Order {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt
  gameId        BigInt
  gameName      String   @db.VarChar(255)
  packageId     BigInt
  packageName   String   @db.VarChar(255)
  packagePrice  Decimal  @db.Decimal(10, 2)
  uid           String   @db.VarChar(255) // Game UID
  status        String   @default("pending") @db.VarChar(20) // pending, processing, completed, failed
  paymentMethod String?  @db.VarChar(50)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @db.Timestamp(0)
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  package       GamePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([gameId])
  @@index([packageId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model Transaction {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt
  type          String   @db.VarChar(50) // topup, purchase, refund
  amount        Decimal  @db.Decimal(10, 2)
  description   String?  @db.Text
  status        String   @default("completed") @db.VarChar(20) // pending, completed, failed
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model Game {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  image       String?  @db.VarChar(500)
  categoryId  BigInt?
  label       GameLabel @default(NONE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)

  category    GameCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  packages    GamePackage[]
  orders      Order[]

  @@index([slug])
  @@index([isActive])
  @@index([categoryId])
  @@map("games")
}

model GameCategory {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)

  games       Game[]

  @@index([isActive])
  @@map("game_categories")
}

model GamePackage {
  id          BigInt   @id @default(autoincrement())
  gameId      BigInt
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  discount    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  orders      Order[]
  
  @@index([gameId])
  @@index([isActive])
  @@map("game_packages")
}

model Banner {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(uuid()) @db.Char(36)
  image       String   @db.VarChar(500)
  title       String?  @db.VarChar(255)
  description String?  @db.Text
  redirectUrl String   @db.VarChar(500)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  
  @@index([isActive])
  @@index([order])
  @@index([createdAt])
  @@map("banners")
}
